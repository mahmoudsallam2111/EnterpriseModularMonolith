{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=emm;Username=emm;Password=emm",
    "Audit":    "Host=localhost;Port=5432;Database=AuditDb;Username=emm;Password=emm",
    "Redis":    "localhost:6379"
  },
  "Auditing": {
    "Enabled": true,
    "AuditQueries": false,
    "AuditFailures": true,
    "ChannelCapacity": 10000,
    "BatchSize": 100,
    "BatchTimeoutMs": 200,
    "MaxPropertyValueLength": 1000,
    "AnonymousUserName": "anonymous",
    "RetentionDays": 365,
    "RetentionCron": "0 15 3 * * ?",
    "SensitivePropertyNames": [ "password", "passwordhash", "token", "secret", "apikey", "signingkey", "authorization", "creditcard" ],
    "ExcludedEntityTypes": [
      "BuildingBlocks.EventBus.Outbox.OutboxMessage",
      "BuildingBlocks.EventBus.Inbox.InboxMessage"
    ]
  },
  "FileStorage": {
    "Provider": "Local",
    "MaxFileSizeBytes": 52428800,
    "AllowedContentTypes": [],
    "VirusScanEnabled": false,
    "SigningKey": "REPLACE-ME-WITH-A-32+CHAR-SECRET-FOR-PRESIGNED-URLS",
    "PublicBaseUrl": "",
    "Local": {
      "RootPath": "App_Data/files",
      "BaseUrl": "http://localhost:5000",
      "RoutePrefix": "/api/v1/files"
    },
    "S3": {
      "Endpoint": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "BucketPrefix": "emm-",
      "ForcePathStyle": false
    },
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerPrefix": "emm-"
    },
    "ClamAv": {
      "Host": "localhost",
      "Port": 3310,
      "TimeoutMs": 15000
    }
  },
  "Platform": {
    "Cache": {
      "Provider": "InMemory",
      "Redis": {
        "KeyPrefix": "emm:cache:"
      }
    },
    "DistributedLock": {
      "Provider": "InMemory",
      "Redis": {
        "KeyPrefix": "emm:locks:"
      }
    }
  },
  "Jwt": {
    "Issuer": "EnterpriseModularMonolith",
    "Audience": "EnterpriseModularMonolith",
    "SigningKey": "REPLACE-ME-WITH-A-32+CHAR-SECRET-FROM-USER-SECRETS-OR-KEY-VAULT",
    "AccessTokenLifetimeMinutes": 60
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Migrations": {
    "RunOnStartup": false
  },
  "FeatureManagement": {
    "Customers.AdvancedSearch": true,
    "Orders.AsyncPayment": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  },
  "AllowedHosts": "*"
}
