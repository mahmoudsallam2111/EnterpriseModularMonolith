{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=emm;Username=emm;Password=emm"
  },
  "Jwt": {
    "Issuer": "EnterpriseModularMonolith",
    "Audience": "EnterpriseModularMonolith",
    "SigningKey": "REPLACE-ME-WITH-A-32+CHAR-SECRET-FROM-USER-SECRETS-OR-KEY-VAULT",
    "AccessTokenLifetimeMinutes": 60
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Migrations": {
    "RunOnStartup": true
  },
  "FeatureManagement": {
    "Customers.AdvancedSearch": true,
    "Orders.AsyncPayment": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  },
  "AllowedHosts": "*"
}
