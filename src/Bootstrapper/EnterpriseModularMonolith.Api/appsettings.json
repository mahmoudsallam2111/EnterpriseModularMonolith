{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=emm;Username=emm;Password=emm",
    "Redis": "localhost:6379"
  },
  "Platform": {
    "Cache": {
      "Provider": "InMemory",
      "Redis": {
        "KeyPrefix": "emm:cache:" // Note: change it to some thing spacific to your app
      }
    },
    "DistributedLock": {
      "Provider": "InMemory",
      "Redis": {
        "KeyPrefix": "emm:locks:" // Note: change it to some thing spacific to your app
      }
    }
  },
  "Jwt": {
    "Issuer": "EnterpriseModularMonolith",
    "Audience": "EnterpriseModularMonolith",
    "SigningKey": "REPLACE-ME-WITH-A-32+CHAR-SECRET-FROM-USER-SECRETS-OR-KEY-VAULT",
    "AccessTokenLifetimeMinutes": 60
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Migrations": {
    "RunOnStartup": false // will be false in production, you should run migrations manually using the migrator project to reduce startup time and avoid potential issues with running migrations on app startup in production
  },
  "FeatureManagement": {
    "Customers.AdvancedSearch": true,
    "Orders.AsyncPayment": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  },
  "AllowedHosts": "*"
}
